# Never send source-control metadata, credentials, local environments, or generated
# artifacts to Docker/Railway.  Both images build from the repository root.
.git
.github
.railway
.env
.env.*
!.env.example
.npmrc
.pypirc
*.pem
*.key
.venv
venv
**/__pycache__
**/*.py[cod]
.pytest_cache
.ruff_cache
.coverage
htmlcov
*.egg-info
.DS_Store

# Frontend dependencies/output are recreated by `npm ci` inside the build stage.
frontend/node_modules
frontend/dist

# Research/test artifacts are not required by either production image.
tests
tasks
docs
data/cache
*.csv
*.parquet
