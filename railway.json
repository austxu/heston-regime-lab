{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "docker/Dockerfile.api",
    "watchPatterns": [
      "/api/**",
      "/analysis/**",
      "/calibration/**",
      "/configs/**",
      "/data/**",
      "/models/**",
      "/.dockerignore",
      "/docker/Dockerfile.api",
      "/requirements.txt",
      "/railway.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
