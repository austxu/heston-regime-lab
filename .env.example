# Copy to `.env` for Docker Compose. This template is safe to commit; never put real
# credentials in `.env.example`.
HRL_OFFLINE=1
FRED_API_KEY=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
# Compose defaults: IPv4 API listener and no trusted proxy in front of nginx.
UVICORN_HOST=0.0.0.0
TRUST_UPSTREAM_PROXY=0
DNS_RESOLVER=127.0.0.11
